{
  "command": "run",
  "run": "review_runs/semeval_2020_task11_sanity",
  "output_dir": "review_runs/semeval_2020_task11_sanity/feature_extract_pdf",
  "goal": "goal.md",
  "api_key_env": "GEMINI_API_KEY",
  "model": "gemini-3.1-flash-lite",
  "base_url": "https://generativelanguage.googleapis.com/v1beta",
